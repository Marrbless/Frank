# Role label for constrained phone or agent runs.
PBOT_ROLE=agent

# Disable local process execution by default on phone deployments.
PBOT_ALLOW_EXEC=0

# Disable unrestricted network access by default on phone deployments.
PBOT_ALLOW_NETWORK=0

# Approval posture expected for restricted agent deployments.
PBOT_APPROVAL_MODE=restricted
